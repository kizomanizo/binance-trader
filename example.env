# App Details
APP_NAME=Binance Trader
APP_VERSION=1.0.0
APP_PORT=3030

# Telegram Bot Details
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Binance API Details
BINANCE_WS_URL=wss://data-stream.binance.com/ws/btcusdt@kline_1m
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
DEFAULT_TRADE_AMOUNT_USDT=5.00

# Dynamic symbols list (comma-separated, lowercase)
SYMBOLS=btcusdt,ethusdt,solusdt,dogeusdt

# Security password required to authorize live trade execution
TRADE_PASSWORD=MySecretTraderPass2026!

# SQLite Database Filename
DB_PATH=trades.db